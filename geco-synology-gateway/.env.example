# ==========================================================================
# GECO Synology Gateway — configuration
# À installer sur un mini-PC ou serveur Linux du même réseau local que le NAS.
# Ne JAMAIS committer de vrai mot de passe dans le dépôt.
# ==========================================================================

NODE_ENV=production
PORT=8787
LOG_LEVEL=info

# ---- Identité machine-to-machine (plateforme GECO) -----------------------
# Doit correspondre aux secrets configurés côté Cloudflare Worker :
#   GECO_GATEWAY_ID  / GECO_GATEWAY_SECRET (>= 64 caractères)
GECO_GATEWAY_ID=
GECO_GATEWAY_SECRET=

# URL publique de la plateforme GECO (Cloudflare Pages / Worker)
GECO_API_URL=

# Intervalle (ms) entre deux polls des tâches
POLL_INTERVAL_MS=5000
# Intervalle (ms) entre deux heartbeats
HEARTBEAT_INTERVAL_MS=30000

# ---- Synology DS112 (accès SMB, local uniquement) ------------------------
# Ne JAMAIS exposer ces valeurs dans le frontend.
SYNOLOGY_HOST=
SYNOLOGY_SMB_SHARE=GECO
SYNOLOGY_SMB_DOMAIN=WORKGROUP
SYNOLOGY_SMB_USERNAME=
SYNOLOGY_SMB_PASSWORD=

# Racine logique (à l'intérieur du partage) que le Gateway peut lire/écrire.
# Toujours relative au partage SMB — jamais un chemin absolu du NAS.
GECO_STORAGE_ROOT=

# ---- Limites --------------------------------------------------------------
MAX_FILE_SIZE=5368709120        # 5 Gio
HMAC_TIMESTAMP_TOLERANCE=300    # 5 minutes
RATE_LIMIT_MAX=600              # requêtes / minute (API locale)

# ---- Chemins locaux (Gateway) --------------------------------------------
DATA_DIR=./data
LOG_DIR=./logs
