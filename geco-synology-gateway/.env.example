# ==========================================================================
# GECO Synology Gateway — configuration locale (Windows / Linux)
# NE JAMAIS committer ce fichier une fois rempli.
# ==========================================================================

NODE_ENV=production
PORT=8787
LOG_LEVEL=info

# ---- Identité machine-to-machine (plateforme GECO) -----------------------
# Doit correspondre exactement aux secrets configurés côté Cloudflare Worker.
GECO_GATEWAY_ID=geco-gateway-01
GECO_GATEWAY_SECRET=REMPLACER_PAR_LE_SECRET_HMAC_64_CARACTERES_MINIMUM

# URL publique de la plateforme GECO
GECO_API_URL=https://btp-smar.lovable.app

# Intervalles (ms)
POLL_INTERVAL_MS=5000
HEARTBEAT_INTERVAL_MS=30000

# ---- Synology DS112 (accès SMB, local uniquement) ------------------------
# Nom d'hôte ou IP du NAS sur le LAN, jamais exposé à Internet.
SYNOLOGY_HOST=192.168.1.21
SYNOLOGY_SMB_SHARE=GECO
SYNOLOGY_SMB_DOMAIN=WORKGROUP

# Identifiants SMB — DEUX MODES POSSIBLES :
#  1. Les laisser ici (déconseillé en production, mot de passe en clair).
#  2. Les stocker dans le Windows Credential Manager :
#       npm run credentials -- set <user> <password>
#     puis SUPPRIMER les deux lignes ci-dessous. Le Gateway récupérera
#     automatiquement l'entrée cmdkey associée à SYNOLOGY_HOST.
SYNOLOGY_SMB_USERNAME=geco_connector
SYNOLOGY_SMB_PASSWORD=REMPLACER_PAR_LE_MOT_DE_PASSE_DU_COMPTE_SMB

# ---- Reconnexion automatique / backoff -----------------------------------
# Nombre de tentatives et fenêtre de délai (ms) pour rétablir la session UNC
# quand le NAS ou le LAN devient temporairement indisponible.
SMB_RECONNECT_MAX_RETRIES=6
SMB_RECONNECT_MIN_DELAY_MS=500
SMB_RECONNECT_MAX_DELAY_MS=30000

# Racine logique à l'intérieur du partage (vide = racine du partage).
GECO_STORAGE_ROOT=

# ---- Limites --------------------------------------------------------------
MAX_FILE_SIZE=5368709120
HMAC_TIMESTAMP_TOLERANCE=300
RATE_LIMIT_MAX=600

# ---- Chemins locaux -------------------------------------------------------
DATA_DIR=./data
LOG_DIR=./logs
