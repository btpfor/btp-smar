    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "better-sqlite3": "^11.3.0",
    "chokidar": "^4.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "mime-types": "^2.1.35",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "smb2": "^0.2.11",
    "undici": "^6.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
