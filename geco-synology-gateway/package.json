{
  "name": "geco-synology-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "GECO Synology Gateway — service Node.js autonome (Windows) reliant la plateforme GECO au NAS Synology DS112 via le client SMB natif de Windows.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "doctor": "tsx src/scripts/doctor.ts",
    "test:synology": "tsx src/scripts/test-synology.ts",
    "test:gateway": "tsx src/scripts/test-gateway.ts"
  },
  "engines": {
    "node": ">=20.11"
  },
  "os": [
    "win32"
  ],
  "dependencies": {
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "better-sqlite3": "^11.3.0",
    "chokidar": "^4.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "mime-types": "^2.1.35",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "undici": "^6.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
