{
  "name": "geco-synology-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "GECO Synology Gateway — service intermédiaire entre la plateforme GECO (Cloudflare) et le Synology DS112 via SMB.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
