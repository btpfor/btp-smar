NODE_ENV=production
PORT=8080

# Racine autorisée dans le conteneur (monter /volume1/GECO ici)
GECO_STORAGE_ROOT=/data/geco

# Identité machine-to-machine (générer un secret aléatoire fort)
GECO_CONNECTOR_ID=synology-nas-01
GECO_CONNECTOR_SECRET=change-me-openssl-rand-hex-64

# API GECO à contacter (webhooks)
GECO_API_URL=https://btp-smar.lovable.app
GECO_WEBHOOK_PATH=/api/synology/webhook

# Limites
MAX_FILE_SIZE=5368709120        # 5 GiB
UPLOAD_CHUNK_SIZE=8388608       # 8 MiB
HMAC_TIMESTAMP_TOLERANCE=300    # 5 min
RATE_LIMIT_MAX=600              # requêtes / min

# Options
LOG_LEVEL=info
WEBHOOK_RETRY_ENABLED=true
WATCHER_ENABLED=true

# Chemins internes (conteneur)
DATA_DIR=/app/data
LOG_DIR=/app/logs
